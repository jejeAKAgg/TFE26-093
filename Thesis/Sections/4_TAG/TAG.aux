\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces The constraint-based determinization pipeline. Accumulated hits and misses are used as spatial constraints to guide hypothesis generation. The engine produces a coherent hypothetical opponent grid that is injected into the simulation copy instead of the true hidden state.}}{21}{figure.caption.8}\protected@file@percent }
\newlabel{fig:det_pipeline}{{3.2}{21}{The constraint-based determinization pipeline. Accumulated hits and misses are used as spatial constraints to guide hypothesis generation. The engine produces a coherent hypothetical opponent grid that is injected into the simulation copy instead of the true hidden state}{figure.caption.8}{}}
\newlabel{fig:det_pipeline@cref}{{[figure][2][3]3.2}{[1][21][]21}}
\citation{morenville2024beliefsg,morenville2025belief_constraints}
\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces Example of a constraint-based hypothetical configuration. Red cells are confirmed hits; grey cells are confirmed misses. The hypothesized fleet placement (blue) covers all hit cells and avoids all miss cells, representing one plausible world consistent with the agent's observations.}}{22}{figure.caption.9}\protected@file@percent }
\newlabel{fig:det_example}{{3.3}{22}{Example of a constraint-based hypothetical configuration. Red cells are confirmed hits; grey cells are confirmed misses. The hypothesized fleet placement (blue) covers all hit cells and avoids all miss cells, representing one plausible world consistent with the agent's observations}{figure.caption.9}{}}
