\@writefile{lof}{\contentsline {figure}{\numberline {3.8}{\ignorespaces Distribution of the HP difference between winner and loser at the end of each game, shown for all three determinization strategies. Under Random Determinization, the majority of games end with a margin of 1 HP; under Constraint-Based and Heatmap-Guided Determinization, the distribution flattens toward larger margins (1000ms budget).}}{31}{figure.caption.15}\protected@file@percent }
\newlabel{fig:drama}{{3.8}{31}{Distribution of the HP difference between winner and loser at the end of each game, shown for all three determinization strategies. Under Random Determinization, the majority of games end with a margin of 1 HP; under Constraint-Based and Heatmap-Guided Determinization, the distribution flattens toward larger margins (1000ms budget)}{figure.caption.15}{}}
\newlabel{fig:drama@cref}{{[figure][8][3]3.8}{[1][31][]31}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.9}{\ignorespaces Average copy latency (top) and total forward model calls per game (bottom) for Constraint-Based and Heatmap-Guided Determinization (10, 50, and 100 heatmap iterations). Despite a higher copy latency under Heatmap-Guided Determinization, the number of forward model calls remains comparable across all strategies.}}{32}{figure.caption.16}\protected@file@percent }
\newlabel{fig:copy_latency_and_fm_calls}{{3.9}{32}{Average copy latency (top) and total forward model calls per game (bottom) for Constraint-Based and Heatmap-Guided Determinization (10, 50, and 100 heatmap iterations). Despite a higher copy latency under Heatmap-Guided Determinization, the number of forward model calls remains comparable across all strategies}{figure.caption.16}{}}
